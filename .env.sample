DEVELOPMENT_MODE=development
# Interactive API docs (Scalar) at /docs — default on when DEVELOPMENT_MODE=development
# ENABLE_API_DOCS=true
API_KEY=
SERVER_PORT=8080
# App connection for Hublio (separate from Navicat project DB).
DB_HOST=localhost
DB_PORT=5432
DB_USER=hublio
DB_PASSWORD=hublio
DB_NAME=hublio
DB_SSLMODE=disable

# Bootstrap admin. On WSL/Ubuntu you can leave password empty and the script
# will fall back to: sudo -u postgres psql (peer auth).
# Do NOT use a limited Navicat user (e.g. duler) here — it cannot CREATE ROLE.
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=
DB_ADMIN_DB=postgres
# DB_ADMIN_USE_PEER=1
# DB_VIA_DOCKER=1
# DB_DOCKER_CONTAINER=postgres

REDIS_ADDRESS=localhost:6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_DB=0

RATE_LIMIT_REQUESTS_SEC=5
RATE_LIMIT_BURST=10

LIMIT_ITEMS_PER_PAGE=10

JWT_SECRET_KEY=
JWT_ENCRYPT_KEY=

FRONTEND_URL=

MAIL_PROVIDER_TYPE=mailtrap

MAILTRAP_API_KEY=
MAILTRAP_API_URL=
MAILTRAP_MAIL_SENDER=
MAILTRAP_NAME_SENDER=

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
