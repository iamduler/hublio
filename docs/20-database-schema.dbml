///////////////////////////////////////////////////////////
// Hublio
// Database Schema
// Version 1.0
// Architecture Freeze v1
///////////////////////////////////////////////////////////

Project Hublio { 
  database_type: "PostgreSQL"

  Note: '''
  Hublio Database Schema

  Principles

  - UUID v7 Primary Keys
  - PostgreSQL
  - Domain Driven Design
  - Aggregate First
  - Multi-tenancy
  - Immutable Runtime History
  - Provider Agnostic
  '''
}

///////////////////////////////////////////////////////////
// ENUMS
///////////////////////////////////////////////////////////

Enum organization_status {
  active
  suspended
  archived
}

Enum workspace_status {
  active
  disabled
}

Enum connector_status {
  registered
  enabled
  disabled
  removed
}

Enum connection_status {
  draft
  verifying
  active
  verification_failed
  disabled
}

Enum intent_status {
  submitted
  accepted
  rejected
  expired
}

Enum execution_status {
  created
  queued
  running
  succeeded
  failed
  cancelled
  expired
  dead_letter
}

Enum execution_step_type {
  validate
  transform_request
  invoke_connector
  transform_response
  publish_event
}

Enum execution_step_status {
  pending
  running
  succeeded
  failed
}

Enum event_category {
  runtime
  business
  system
}

Enum credential_type {
  api_key
  oauth2
  bearer_token
  basic_auth
  jwt
}

Enum workspace_role {
    owner
    admin
    member
}

Enum user_status {
  active
  inactive
  suspended
  archived
}

Enum api_key_status {
  active
  disabled
}

Enum connector_category {
  source
  destination
  bidirectional
  utility
}

Enum connector_capability_status {
  enabled
  disabled
}

Enum credential_status {
  active
  expired
  revoked
}

Enum execution_result {
  success
  failed
  cancelled
  expired
  dead_letter
}

Enum snapshot_type {
  canonical_request
  provider_request
  provider_response
  canonical_response
}

Enum aggregate_type {
  organization
  workspace
  connector
  connection
  intent
  execution
  sync_route
}

Enum actor_type {
  user
  api_key
  system
}

///////////////////////////////////////////////////////////
// SHARED CONVENTIONS
///////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////
// Every primary key
//
// id uuid
//
// UUID v7 generated by application
///////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////
// Audit Columns
//
// created_at
//
// updated_at
//
// deleted_at (configuration tables only)
///////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////
// Runtime Tables
//
// created_at
//
// started_at
//
// completed_at
///////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////
// JSONB Usage
//
// config
//
// payload
//
// context
//
// snapshot
//
// metadata
///////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////
// MULTI TENANCY
///////////////////////////////////////////////////////////

Table organizations {
  id uuid [pk]
  name varchar(255)

  status organization_status

  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    name [unique]
  }

  Note: 'Tenant root'
}

Table workspaces {
  id uuid [pk]
  organization_id uuid

  name varchar(150)
  environment varchar(50)

  status workspace_status

  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz

  Note: 'Logical isolation inside an Organization'

  indexes {
    (organization_id, name) [unique]
  }
}

Table users {
  id uuid [pk]
  organization_id uuid
  email varchar(255)
  full_name varchar(255)
  is_active boolean

  password_hash varchar(255)
  email_verified_at timestamptz
  password_changed_at timestamptz
  last_login_at timestamptz
  status user_status

  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    email [unique]
  }
}

Table workspace_users {
  workspace_id uuid
  user_id uuid
  role workspace_role
  created_at timestamptz

  indexes {
    (workspace_id, user_id) [pk]
  }
}

Table api_keys {
  id uuid [pk]
  workspace_id uuid

  name varchar(255)

  key_hash varchar(255)
  last_used_at timestamptz

  expires_at timestamptz
  status api_key_status
  prefix varchar(10)
  last_used_ip inet
  last_used_user_agent text

  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    key_hash [unique]
  }
}

///////////////////////////////////////////////////////////
//
// INTEGRATION
//
///////////////////////////////////////////////////////////

Table connectors {
  id uuid [pk]
  code varchar(100) [unique]
  name varchar(255)
  vendor varchar(255)
  category connector_category
  version varchar(50)
  status connector_status
  description text
  homepage varchar(500)
  documentation_url varchar(500)
  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    code [unique]
  }

  Note: 'Installed Connector'
}

///////////////////////////////////////////////////////////

Table connector_capabilities {
  id uuid [pk]
  connector_id uuid
  capability_code varchar(150)
  display_name varchar(255)

  status connector_capability_status
  is_async boolean

  created_at timestamptz
  updated_at timestamptz

  indexes {
    (connector_id, capability_code) [unique]
  }
}

///////////////////////////////////////////////////////////

Table connections {
  id uuid [pk]
  active_credential_id uuid
  workspace_id uuid
  connector_id uuid

  name varchar(255)
  is_default boolean

  description text
  environment varchar(50)
  status connection_status
  config jsonb
  retry_policy jsonb
  timeout_seconds integer

  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    workspace_id
    connector_id
    status
    (workspace_id, name) [unique]
  }
}

///////////////////////////////////////////////////////////

Table credentials {
  id uuid [pk]
  connection_id uuid
  type credential_type
  status credential_status
  version integer
  encrypted_secret jsonb
  expires_at timestamptz
  rotated_at timestamptz
  created_at timestamptz
  updated_at timestamptz
  created_by uuid

  indexes {
    connection_id
    status
  }
}

///////////////////////////////////////////////////////////
//
// INTEGRATION — SyncRoute (configuration, not Runtime Aggregate)
// docs/30 §5.2; AGENTS.md SyncRoute clarification
//
///////////////////////////////////////////////////////////

Enum sync_route_status {
  draft
  enabled
  disabled
}

Enum sync_route_trigger {
  webhook
  schedule
  both
}

Table sync_routes {
  id uuid [pk]
  workspace_id uuid
  source_connection_id uuid

  name varchar(255)
  status sync_route_status
  trigger_type sync_route_trigger

  resource_types jsonb
  schedule jsonb
  filter jsonb
  idempotency_rule jsonb
  activities jsonb
  reverse jsonb
  retry_policy jsonb
  webhook_secret jsonb

  created_at timestamptz
  updated_at timestamptz
  deleted_at timestamptz

  indexes {
    workspace_id
    source_connection_id
    status
    (workspace_id, name) [unique]
  }

  Note: '''
  Workspace-scoped origin → destination fan-out configuration.
  Not a Workflow / BPMN Aggregate. activities JSON describes
  sequential|parallel Execution groups under one Intent.
  webhook_secret is encrypted at rest; plaintext shown once on create/rotate.
  trigger_type: webhook | schedule | both (column name avoids SQL reserved TRIGGER).
  '''
}

Table sync_route_watermarks {
  sync_route_id uuid
  resource_type varchar(100)
  cursor jsonb
  updated_at timestamptz

  indexes {
    (sync_route_id, resource_type) [pk]
    updated_at
  }

  Note: '''
  Poll watermark / cursor per SyncRoute + resource_type (docs/30 §7.2).
  Postgres is source of truth — not Redis.
  '''
}

///////////////////////////////////////////////////////////
//
// ORCHESTRATION
//
///////////////////////////////////////////////////////////

Table intents {
  id uuid [pk]
  organization_id uuid
  workspace_id uuid
  connection_id uuid
  capability varchar(150)
  payload jsonb
  status intent_status
  correlation_id varchar(255)
  idempotency_key varchar(255)
  submitted_at timestamptz
  created_at timestamptz

  indexes {
    organization_id
    workspace_id
    connection_id
    capability
    status
    correlation_id
    idempotency_key [unique]
    (connection_id, submitted_at)
    (organization_id, submitted_at)
  }
}

///////////////////////////////////////////////////////////

Table executions {
  id uuid [pk]
  intent_id uuid
  status execution_status
  result execution_result
  retry_attempt integer

  current_step_no integer
  context jsonb
  failure_reason text
  started_at timestamptz
  completed_at timestamptz
  created_at timestamptz

  indexes {
    intent_id [unique]
    status
    (status, created_at)
    (started_at)
    (completed_at)
  }
}

///////////////////////////////////////////////////////////

Table execution_steps {
  id uuid [pk]

  execution_id uuid
  step_no integer
  step_type execution_step_type
  status execution_step_status
  retry_attempt integer
  duration_ms integer

  error_message text
  error_code varchar(100)
  started_at timestamptz
  completed_at timestamptz

  indexes {
    execution_id
    (execution_id, step_no) [unique]
    (status, started_at)
  }
}

///////////////////////////////////////////////////////////

Table execution_snapshots {
  id uuid [pk]
  execution_id uuid
  step_id uuid
  snapshot_type snapshot_type
  snapshot jsonb
  content_type varchar(100)

  created_at timestamptz

  indexes {
    execution_id
    step_id
    (snapshot_type, created_at)
  }
}

///////////////////////////////////////////////////////////

Table execution_timelines {
  id uuid [pk]
  execution_id uuid
  event varchar(150)
  message text
  metadata jsonb
  created_at timestamptz

  indexes {
    execution_id
    created_at
    (event, created_at)
  }
}

///////////////////////////////////////////////////////////
//
// IDEMPOTENCY
//
///////////////////////////////////////////////////////////

Table idempotency_keys {
  id uuid [pk]
  organization_id uuid
  workspace_id uuid
  idempotency_key varchar(255)
  intent_id uuid
  expires_at timestamptz
  created_at timestamptz

  indexes {
    (organization_id, workspace_id, idempotency_key) [unique]
  }
}

///////////////////////////////////////////////////////////
// EVENTS
///////////////////////////////////////////////////////////

Table events {
  id uuid [pk]

  organization_id uuid
  workspace_id uuid

  aggregate_type aggregate_type
  aggregate_id uuid

  execution_id uuid [note: 'Nullable']
  category event_category

  event_name varchar(150)
  correlation_id varchar(255)

  payload jsonb
  metadata jsonb

  published_by varchar(100)
  created_at timestamptz

  indexes {
    organization_id
    workspace_id
    aggregate_type
    aggregate_id
    execution_id
    category
    event_name
    correlation_id
    created_at    
    (aggregate_type, aggregate_id)    
    (category, created_at)
  }

  Note: '''
  Immutable.
  Append-only.
  Stores Runtime, Business and System Events.
  '''
}

///////////////////////////////////////////////////////////
// AUDIT
///////////////////////////////////////////////////////////
Table audit_logs {
  id uuid [pk]
  organization_id uuid
  workspace_id uuid
  actor_type actor_type
  actor_id uuid
  action varchar(150)
  resource_type varchar(100)
  resource_id uuid
  request_id varchar(255)
  correlation_id varchar(255)
  ip inet
  user_agent text
  metadata jsonb
  created_at timestamptz

  indexes {
    organization_id
    workspace_id
    actor_type
    actor_id
    action
    resource_type
    resource_id
    request_id
    correlation_id
    created_at
    (actor_type, actor_id)    
    (resource_type, resource_id)
  }

  Note: '''
  Immutable.
  Append-only.
  Security and compliance audit trail.
  '''
}

///////////////////////////////////////////////////////////
// RELATIONSHIPS
///////////////////////////////////////////////////////////
Ref: connector_capabilities.connector_id > connectors.id
Ref: connections.connector_id > connectors.id
Ref: connections.workspace_id > workspaces.id
Ref: credentials.connection_id > connections.id
Ref: sync_routes.workspace_id > workspaces.id
Ref: sync_routes.source_connection_id > connections.id
Ref: sync_route_watermarks.sync_route_id > sync_routes.id
Ref: intents.organization_id > organizations.id
Ref: intents.workspace_id > workspaces.id
Ref: intents.connection_id > connections.id
Ref: executions.intent_id > intents.id
Ref: execution_steps.execution_id > executions.id
Ref: execution_snapshots.execution_id > executions.id
Ref: execution_snapshots.step_id > execution_steps.id
Ref: execution_timelines.execution_id > executions.id
Ref: idempotency_keys.intent_id > intents.id
Ref: idempotency_keys.organization_id > organizations.id
Ref: idempotency_keys.workspace_id > workspaces.id
Ref: workspaces.organization_id > organizations.id
Ref: users.organization_id > organizations.id
Ref: workspace_users.workspace_id > workspaces.id
Ref: workspace_users.user_id > users.id
Ref: api_keys.workspace_id > workspaces.id
Ref: connections.active_credential_id > credentials.id
Ref: events.organization_id > organizations.id
Ref: events.workspace_id > workspaces.id
Ref: events.execution_id > executions.id
Ref: audit_logs.organization_id > organizations.id
Ref: audit_logs.workspace_id > workspaces.id